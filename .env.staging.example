# Staging environment template
# Fill this file, save it as .env.staging, and load it before deployment.

NODE_ENV=production
RUN_MODE=shadow
LOG_LEVEL=info
ENABLE_API=true
HTTP_PORT=3000
WS_PORT=3001
METRICS_PORT=9090

JWT_SECRET=replace_with_a_32_plus_char_random_secret
DASHBOARD_USERNAME=staging-admin
DASHBOARD_PASSWORD=replace_with_a_strong_dashboard_password
ALLOW_INSECURE_DEFAULT_AUTH=false

MASTER_KEY=replace_with_your_master_key_if_using_keys_enc

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=replace_if_needed
REDIS_DB=0

CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=replace_if_needed

TRADING_INITIAL_CAPITAL=10000
TRADING_TYPE=swap
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT
DEFAULT_TIMEFRAME=1h

# Use this for public-market shadow tests without private exchange credentials.
USE_SHARED_MARKET_DATA=false
PUBLIC_MARKET_ONLY=false
SHADOW_SKIP_PRIVATE_ACCOUNT_DATA=false
HEALTH_MEMORY_WARNING_PERCENT=99
HEALTH_MEMORY_CRITICAL_PERCENT=100

# Use shadow/demo credentials in staging whenever possible.
BINANCE_API_KEY=your_staging_binance_api_key_here
BINANCE_API_SECRET=your_staging_binance_api_secret_here
BINANCE_TESTNET=false

OKX_API_KEY=your_staging_okx_api_key_here
OKX_API_SECRET=your_staging_okx_api_secret_here
OKX_PASSPHRASE=your_staging_okx_passphrase_here
OKX_SANDBOX=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=your_smtp_password_here
ALERT_EMAIL_TO=ops@example.com

TELEGRAM_BOT_TOKEN=123456789:your_telegram_bot_token_here
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ENABLED=true
