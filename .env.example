# Quant Trading System environment template
# Copy to .env or .env.local and replace placeholders before use.

# Runtime
NODE_ENV=development
RUN_MODE=shadow
LOG_LEVEL=info
ENABLE_API=true
HTTP_PORT=3000
WS_PORT=3001
METRICS_PORT=9090

# Authentication
JWT_SECRET=replace_with_a_32_plus_char_random_secret
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace_with_a_strong_dashboard_password
ALLOW_INSECURE_DEFAULT_AUTH=false

# Encryption
MASTER_KEY=replace_with_your_master_key_if_using_keys_enc

# Trading
TRADING_INITIAL_CAPITAL=10000
TRADING_TYPE=swap
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT
DEFAULT_TIMEFRAME=1h

# Public shadow testing
USE_SHARED_MARKET_DATA=false
PUBLIC_MARKET_ONLY=false
SHADOW_SKIP_PRIVATE_ACCOUNT_DATA=false
HEALTH_MEMORY_WARNING_PERCENT=99
HEALTH_MEMORY_CRITICAL_PERCENT=100

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ClickHouse
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# Exchange credentials
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_SANDBOX=true

BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true

GATE_API_KEY=your_gate_api_key_here
GATE_API_SECRET=your_gate_api_secret_here
GATE_TESTNET=true

# Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=your_smtp_password_here
ALERT_EMAIL_TO=ops@example.com

TELEGRAM_BOT_TOKEN=123456789:your_telegram_bot_token_here
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ENABLED=false

# Risk controls
MAX_LOSS_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_POSITIONS=10
MAX_POSITION_SIZE=0.2
MAX_LEVERAGE=3
